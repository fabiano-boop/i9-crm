# === BANCO DE DADOS ===
DATABASE_URL=postgresql://i9user:i9pass@localhost:5432/i9crm

# === REDIS ===
REDIS_URL=redis://localhost:6379

# === JWT ===
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# JWT de curta duração usado no passo intermediário do login com 2FA (5 min fixo)
# Reutiliza JWT_SECRET — sem variável adicional necessária

# === ANTHROPIC / CLAUDE ===
ANTHROPIC_API_KEY=your-anthropic-key-here

# === GOOGLE SHEETS ===
GOOGLE_SHEETS_ID=your-google-sheet-id-here
# JSON completo da service account (minificado em uma linha)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# === WHAPI CLOUD (WhatsApp) ===
# Token gerado em https://app.whapi.cloud/ > Channel > Token
WHAPI_URL=https://gate.whapi.cloud
WHAPI_TOKEN=your-whapi-token-here

# === EMAIL (Resend) ===
RESEND_API_KEY=your-resend-key-here
EMAIL_FROM=crm@i9solucoes.com.br
EMAIL_FROM_NAME=i9 Soluções Digitais

# === EMAIL FALLBACK (SMTP/Nodemailer) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app

# === BACKUP ===
# URL direta ao banco (sem pooler) — necessária para pg_dump no Supabase
DIRECT_URL=postgresql://i9user:i9pass@db.xxxxx.supabase.co:5432/postgres
# ID da pasta no Google Drive onde os backups serão armazenados
BACKUP_GOOGLE_DRIVE_FOLDER_ID=
# Dias de retenção dos backups no Drive (padrão: 30)
BACKUP_RETENTION_DAYS=30
# Email do admin que recebe alertas de falha no backup
ADMIN_EMAIL=admin@i9solucoes.com.br

# === TRACKING ===
TRACKING_BASE_URL=http://localhost:3001
TRACKING_SECRET=your-tracking-hmac-secret-here-min-32-chars

# === SERVIDOR ===
PORT=3000
TRACKING_PORT=3001
NODE_ENV=development

# === FRONTEND ===
FRONTEND_URL=http://localhost:5173

# === LOGS ===
LOG_LEVEL=info

# === AGENTE IA (WhatsApp) ===
WHATSAPP_AGENT_ENABLED=false  # true = Maya responde leads automaticamente

# === RELATÓRIOS SEMANAIS ===
# URL base do backend para gerar links do PDF no WhatsApp
REPORTS_BASE_URL=https://seu-backend.railway.app
# Caminho do executável do Chromium para geração de PDF via Puppeteer (opcional)
# Em produção no Railway, deixe vazio para usar o Chromium baixado pelo puppeteer
PUPPETEER_EXECUTABLE_PATH=
