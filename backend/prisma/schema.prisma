// This is your Prisma schema file for i9 CRM
// Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================
// USUÁRIOS E AUTENTICAÇÃO
// =====================

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  passwordHash    String
  role            Role             @default(AGENT)
  // SPRINT 3.4: meta mensal de MRR do usuário
  monthlyMrrGoal  Float            @default(0)
  createdAt       DateTime         @default(now())
  leads           Lead[]
  campaigns       Campaign[]
  twoFactorSecret TwoFactorSecret?
}

enum Role {
  ADMIN
  AGENT
}

// =====================
// LEADS
// =====================

model Lead {
  id              String         @id @default(cuid())
  externalId      String?        @unique // ID da linha no Google Sheets: "sheet_row_{rowIndex}"
  name            String
  businessName    String
  niche           String
  neighborhood    String
  address         String?
  phone           String?
  whatsapp        String?
  email           String?
  website         String?
  instagram       String?
  googleRating    Float?
  reviewCount     Int?
  digitalLevel    DigitalLevel   @default(LOW)
  painPoints      String?
  idealService    String?
  upsellService   String?
  urgency         Int            @default(5)
  revenuePotential String?
  closingEase     String?
  score           Int            @default(0)
  classification  Classification @default(COLD)
  whatsappAngle   String?
  source          String?        // origem: Instagram | Google | Indicação | etc.
  status          LeadStatus     @default(NEW)
  pipelineStage   String         @default("new")
  notes               String?
  lastContactAt       DateTime?
  nextFollowUpAt      DateTime?
  recommendedPackage  String?    // basico | pro | premium — enriched from marketIntelligence
  conversionPotential Int?       // 0-100 — segment conversion potential from marketIntelligence
  importedAt          DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  assignedTo      User?          @relation(fields: [assignedToId], references: [id])
  assignedToId    String?
  interactions    Interaction[]
  campaignLeads   CampaignLead[]
  trackingEvents  TrackingEvent[]
  leadCadences       LeadCadence[]
  opportunityAlerts  OpportunityAlert[]
}

enum DigitalLevel {
  LOW
  MEDIUM
  HIGH
}

enum Classification {
  HOT
  WARM
  COLD
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  PROPOSAL
  NEGOTIATION
  CLOSED
  LOST
}

// =====================
// INTERAÇÕES
// =====================

model Interaction {
  id        String          @id @default(cuid())
  lead      Lead            @relation(fields: [leadId], references: [id])
  leadId    String
  type      InteractionType
  channel   String
  content   String
  direction String          @default("OUT") // IN | OUT
  createdAt DateTime        @default(now())
}

enum InteractionType {
  WHATSAPP
  EMAIL
  CALL
  NOTE
}

// =====================
// CAMPANHAS
// =====================

model Campaign {
  id            String         @id @default(cuid())
  name          String
  description   String?
  type          CampaignType
  status        CampaignStatus @default(DRAFT)
  subject       String?        // assunto do email
  bodyText      String         // template WhatsApp ou corpo do email (texto puro)
  bodyHtml      String?        // corpo do email em HTML
  scheduledAt   DateTime?
  sentAt        DateTime?
  pauseReason   String?        // "DAILY_LIMIT_REACHED" | null
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdById   String
  campaignLeads CampaignLead[]
}

enum CampaignType {
  WHATSAPP
  EMAIL
  BOTH
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
}

// =====================
// LEADS DE CAMPANHAS (pivot)
// =====================

model CampaignLead {
  id             String     @id @default(cuid())
  campaign       Campaign   @relation(fields: [campaignId], references: [id])
  campaignId     String
  lead           Lead       @relation(fields: [leadId], references: [id])
  leadId         String
  status         SendStatus @default(PENDING)
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  replied        Boolean    @default(false)
  repliedAt      DateTime?
  errorMsg       String?
  trackingToken  String     @unique @default(cuid())

  @@unique([campaignId, leadId])
}

enum SendStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  FAILED
}

// =====================
// EVENTOS DE TRACKING
// =====================

model TrackingEvent {
  id        String   @id @default(cuid())
  lead      Lead     @relation(fields: [leadId], references: [id])
  leadId    String
  token     String
  type      String   // open | click | reply
  url       String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

// =====================
// HISTÓRICO DE SYNC DO SHEETS
// =====================

model SheetSync {
  id           String   @id @default(cuid())
  syncedAt     DateTime @default(now())
  rowsImported Int
  rowsUpdated  Int
  status       String   // success | error | partial
  errorMsg     String?
}

// =====================
// ALERTAS DE OPORTUNIDADE
// =====================

model OpportunityAlert {
  id          String   @id @default(cuid())
  lead        Lead     @relation(fields: [leadId], references: [id])
  leadId      String
  type        String   // hot_engagement | cooling_lead | no_contact_week
  title       String
  description String
  urgency     Int      @default(5)
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([isRead, isDismissed, createdAt])
}

// =====================
// CADÊNCIA DE FOLLOW-UP
// =====================

model FollowUpSequence {
  id           String        @id @default(cuid())
  name         String
  description  String?
  steps        Json          // FollowUpStep[]
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  leadCadences LeadCadence[]
}

model LeadCadence {
  id           String           @id @default(cuid())
  lead         Lead             @relation(fields: [leadId], references: [id])
  leadId       String
  sequence     FollowUpSequence @relation(fields: [sequenceId], references: [id])
  sequenceId   String
  currentStep  Int              @default(0)
  status       String           @default("active") // active | paused | completed | cancelled
  startedAt    DateTime         @default(now())
  nextActionAt DateTime?
  pausedAt     DateTime?
  pauseReason  String?
  completedAt  DateTime?
  updatedAt    DateTime         @updatedAt

  @@unique([leadId, sequenceId])
}

// =====================
// BACKUP
// =====================

model BackupLog {
  id          String   @id @default(cuid())
  filename    String
  sizeKb      Int
  driveFileId String?
  status      String   @default("success") // success | error
  errorMsg    String?
  triggeredBy String   @default("auto")    // "auto" ou userId
  createdAt   DateTime @default(now())
}

// =====================
// 2FA
// =====================

model TwoFactorSecret {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// =====================
// AUDIT LOG
// =====================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// =====================
// CLIENTES ATIVOS (pós-venda)
// =====================

model Client {
  id            String         @id @default(cuid())
  businessName  String
  ownerName     String
  email         String?
  whatsapp      String?
  address       String?
  neighborhood  String?
  niche         String?
  package       String?        // start | growth | premium
  monthlyValue  Float?
  startDate     DateTime       @default(now())
  status        String         @default("active") // active | paused | churned
  origin              String         @default("lead")   // lead | referral | manual
  leadId              String?
  internalCost        Float?         @default(0)        // custo interno mensal (hora + ferramentas)
  recurringBillingDay Int?           @default(5)        // SPRINT 2: dia do mês para cobrança recorrente (1-28)
  reportSendDay       Int?           @default(6)        // SPRINT 2: dia do mês para envio do relatório (1-28)
  notes               String?
  cancelledAt         DateTime?
  cancellationReason  String?
  // SPRINT 3.5: serviço contratado
  serviceId           String?
  service             Service?       @relation(fields: [serviceId], references: [id])
  // SPRINT 3.6: Google Analytics 4 + Search Console
  ga4PropertyId       String?
  ga4AccessToken      String?        // criptografado AES-256
  ga4RefreshToken     String?        // criptografado AES-256
  ga4TokenExpiresAt   DateTime?
  searchConsoleUrl    String?        // ex: sc-domain:cliente.com.br
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  weeklyReports WeeklyReport[]
  invoices      Invoice[]            // SPRINT 2: faturas do cliente

  @@index([status])
  @@index([serviceId])
}

// =====================
// RELATÓRIOS SEMANAIS
// =====================

model WeeklyReport {
  id              String   @id @default(cuid())
  client          Client   @relation(fields: [clientId], references: [id])
  clientId        String
  weekStart       DateTime
  weekEnd         DateTime

  // Métricas da semana
  messagesSent    Int      @default(0)
  messagesRead    Int      @default(0)
  repliesReceived Int      @default(0)
  newLeadsGen     Int      @default(0)
  appointmentsSet Int      @default(0)
  conversionRate  Float    @default(0)

  // Conteúdo gerado por Claude
  highlights      String?
  recommendations String?
  nextWeekPlan    String?

  // Entrega
  pdfPath         String?
  sentViaEmail    Boolean  @default(false)
  sentViaWhatsApp Boolean  @default(false)
  sentAt          DateTime?

  createdAt DateTime @default(now())

  @@index([clientId, weekStart])
}

// =====================
// SERVIÇOS / PRODUTOS
// =====================

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // site | landing_page | trafego | social_media | criativo | app | consultoria
  promoPrice  Float
  normalPrice Float
  billingType String   @default("RECURRING") // SPRINT 2: RECURRING | ONE_TIME
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // SPRINT 3.5: clientes que contrataram este serviço
  clients     Client[]
}

// =====================
// FATURAS (SPRINT 2)
// =====================

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id             String        @id @default(cuid())
  client         Client        @relation(fields: [clientId], references: [id])
  clientId       String
  description    String
  amount         Float
  dueDate        DateTime
  status         InvoiceStatus @default(PENDING)
  paidAt         DateTime?
  referenceMonth String?       // ex: "2026-04"
  origin         String        @default("manual") // manual | auto_recurring | auto_conversion
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([clientId, status])
  @@index([dueDate, status])
}

// =====================
// ANTI-BAN WHATSAPP
// =====================

model WhatsAppDailyStats {
  id   String @id @default(cuid())
  date String @unique  // "YYYY-MM-DD"
  sent Int    @default(0)
}

model WhatsAppConfig {
  id               String   @id @default("default")
  warmupStartDate  DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
